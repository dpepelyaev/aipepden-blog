---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<BaseLayout
  title="Блог AiPepDen — AI-агенты для бизнеса"
  description="Практические статьи об AI-автоматизации бизнеса: маркетинг, продажи, поддержка клиентов без найма"
>
  <section class="blog-hero">
    <div class="container">
      <p class="hero-label">Блог</p>
      <h1 class="hero-title">AI-агенты для бизнеса</h1>
      <p class="hero-desc">Практические статьи об автоматизации маркетинга, продаж и поддержки. Без воды — только то, что работает.</p>
    </div>
  </section>

  <section class="blog-list">
    <div class="container">
      {posts.length === 0 ? (
        <p class="empty">Статьи скоро появятся.</p>
      ) : (
        <div class="posts-grid">
          {posts.map(post => (
            <article class="post-card">
              <div class="post-card-meta">
                <time datetime={post.data.pubDate.toISOString()} class="post-card-date">
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="post-card-tags">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <h2 class="post-card-title">
                <a href={`/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p class="post-card-desc">{post.data.description}</p>
              <a href={`/${post.slug}/`} class="post-card-link" aria-label={`Читать: ${post.data.title}`}>
                Читать статью →
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-banner">
        <div>
          <h2>Хотите так же?</h2>
          <p>Внедрим AI-агентов в ваш бизнес. Первый аудит — бесплатно.</p>
        </div>
        <a href="https://aipepden.store/audit-free/" class="cta-btn">
          Получить бесплатный аудит
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: 4rem 0 3rem;
    background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--border);
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .hero-desc {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 600px;
    line-height: 1.6;
  }

  .blog-list {
    padding: 3rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  .post-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-card-date {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .post-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    font-family: var(--font-mono);
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .post-card-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .post-card-title a:hover {
    color: var(--accent);
  }

  .post-card-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    flex: 1;
  }

  .post-card-link {
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 0.2s;
  }

  .post-card-link:hover {
    text-decoration: underline;
  }

  .empty {
    color: var(--text-muted);
    text-align: center;
    padding: 3rem;
  }

  .cta-section {
    padding: 3rem 0;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
  }

  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: var(--bg-3);
    border: 1px solid var(--accent);
    border-radius: 16px;
    padding: 2rem 2.5rem;
  }

  @media (max-width: 640px) {
    .cta-banner {
      flex-direction: column;
      text-align: center;
    }
  }

  .cta-banner h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .cta-banner p {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .cta-btn {
    flex-shrink: 0;
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .cta-btn:hover {
    opacity: 0.9;
    text-decoration: none;
  }
</style>
