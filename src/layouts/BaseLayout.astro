---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Блог AiPepDen — AI-агенты для бизнеса', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="https://aipepden.store" class="logo" aria-label="AiPepDen — главная">
        <span class="logo-icon">AI</span>
        <span class="logo-text">PepDen</span>
      </a>
      <nav aria-label="Основная навигация">
        <a href="/">Блог</a>
        <a href="https://aipepden.store">Главная</a>
        <a href="https://aipepden.store/audit-free/" class="btn-cta">Бесплатный аудит</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="https://aipepden.store" class="logo">
            <span class="logo-icon">AI</span>
            <span class="logo-text">PepDen</span>
          </a>
          <p>AI-агенты для автоматизации бизнеса. Маркетинг, продажи, поддержка — без найма.</p>
        </div>
        <div class="footer-links">
          <h3>Блог</h3>
          <a href="/">Все статьи</a>
        </div>
        <div class="footer-links">
          <h3>Компания</h3>
          <a href="https://aipepden.store">О нас</a>
          <a href="https://aipepden.store/audit-free/">Бесплатный аудит</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} AiPepDen. Все права защищены.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  .site-header {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text);
  }

  .logo:hover {
    text-decoration: none;
  }

  .logo-icon {
    background: var(--accent);
    color: var(--bg);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
    letter-spacing: -0.02em;
  }

  .logo-text {
    color: var(--text);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  nav a {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .btn-cta {
    background: var(--accent) !important;
    color: var(--bg) !important;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    transition: opacity 0.2s !important;
  }

  .btn-cta:hover {
    opacity: 0.9;
    text-decoration: none !important;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .site-footer {
    margin-top: auto;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    padding: 3rem 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    nav {
      gap: 1rem;
    }
  }

  .footer-brand p {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links h3 {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    color: var(--text-muted);
    font-size: 0.8rem;
  }
</style>
